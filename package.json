{
  "name": "kysely-context",
  "version": "1.0.1",
  "description": "Context manager for Kysely using AsyncLocalStorage",
  "keywords": [
    "async-local-storage",
    "context",
    "kysely",
    "transaction"
  ],
  "license": "MIT",
  "author": "Andrey Varfolomeev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andvarfolomeev/kysely-context.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "fmt": "bun oxfmt",
    "fmt:check": "bun oxfmt --check",
    "lint": "bun oxlint"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.16.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.50.0",
    "pg": "^8.19.0"
  },
  "peerDependencies": {
    "kysely": "^0.x",
    "typescript": "^5"
  }
}
